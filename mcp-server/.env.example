# ===== ELLIS MCP Server 환경변수 =====

# Search Gateway API base URL (필수 — MOCK_MODE=true 면 사용되지 않음)
ELLIS_GATEWAY_URL=https://gateway.ohmyhotel.biz

# Gateway 서비스 인증 API Key (MOCK_MODE=false 일 때 필수)
GATEWAY_API_KEY=

# Agent(셀러) 컨텍스트 토큰 (MOCK_MODE=false 일 때 필수)
AGENT_TOKEN=

# 서버가 신뢰하는 agent_id — 도구 입력의 agent_id 는 항상 이 값으로 덮어씀
AGENT_ID=AGENT-LOCAL

# 권한 롤: AGENT_ADMIN | AGENT_USER
#  - AGENT_USER 는 net_price / markup / supplier_id 가 응답에서 제거(마스킹)됨
ROLE=AGENT_USER

# Gateway HTTP 요청 timeout (ms) — 기본 20000
REQUEST_TIMEOUT_MS=20000

# 네트워크 오류 재시도 횟수 (4xx/5xx 응답은 재시도하지 않음) — 기본 2
MAX_RETRIES=2

# 재시도 지수 백오프 기본 지연 (ms) — 기본 250
RETRY_BACKOFF_MS=250

# 도구 호출 분당 허용 횟수 (토큰버킷) — 기본 30
RATE_LIMIT_PER_MINUTE=30

# search_id 결과 캐시 TTL (ms) — compare_hotel_rates 용, 기본 30분
RESULT_CACHE_TTL_MS=1800000

# true 면 실제 Gateway 없이 현실적인 mock 데이터로 동작 (로컬 실행/테스트용)
MOCK_MODE=false

# 로그 레벨: debug | info | warn | error (로그는 stderr 로만 출력됨)
LOG_LEVEL=info
